async function enrich() {
    for (const update of updates) {
        try {
            console.log(`Patching ${update.id}...`)
            await client.patch(update.id).set(update.patch).commit()
            console.log(`Successfully patched ${update.id}`)
        } catch (err) {
            console.error(`Failed to patch ${update.id}:`, err.message)
        }
    }
}

enrich()
