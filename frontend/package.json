  },
  "dependencies": {
    "@portabletext/react": "^6.0.2",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.562.0",
    "next": "^15.1.7",
    "next-sanity": "^9.5.0",
    "next-seo": "^7.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.8.0",
    "schema-dts": "^1.1.5"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260120.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.59.3"
  }
